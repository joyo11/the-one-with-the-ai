# Large generated artifacts — regenerate locally by running the scripts:
#   classifier/prepare_data.py — re-downloads emorynlp dataset
#   classifier/train.py        — re-trains DistilBERT
#   chatbots/build_index.py    — re-embeds character lines
#   server/precompute_game_lines.py — re-scores game lines
# Per the brief's IP guardrail we also do NOT ship the cleaned transcript CSV.
classifier/data/
classifier/models/
chatbots/index/
server/game_lines.jsonl
# hf-space mirrors the regenerable index + game lines (and the .texts.json files
# contain the dialogue we don't ship per the IP guardrail) — keep them out too.
hf-space/index/
hf-space/game_lines.jsonl

# Eval intermediates (keep scorecard.csv as the published result)
evals/data/

